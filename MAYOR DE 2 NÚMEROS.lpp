real num1,num2

Inicio

     escriba "Ingrese el primer número: "
     lea num1

     escriba "Ingrese el segundo número: "
     lea num2

     si num1 > num2 entonces
     escriba "El mayor es: ", num1
     sino
     si num2 > num1 entonces
     escriba "El mayor es: ", num2
     sino
     escriba "Los números son iguales"
     fin si
     fin si

Fin