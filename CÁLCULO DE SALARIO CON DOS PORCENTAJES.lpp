real salario,descuento,total

Inicio

    escriba "Ingrese el salario: "
    lea salario

    si salario > 1500000 entonces
      descuento <- salario * 0.10
    sino
      descuento <- salario * 0.05
    fin si
      total <- salario - descuento

    escriba "Descuento: ", descuento
    escriba "Salario final: ", total

Fin